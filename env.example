# Nifty AI Predictor — Environment Variables
# Copy this file to .env and fill in your keys

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Get free key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── OPTIONAL (for future broker API integration) ──────────────────────────────
# Zerodha Kite API (upgrade later for real-time data)
# ZERODHA_API_KEY=
# ZERODHA_API_SECRET=
# ZERODHA_ACCESS_TOKEN=

# Upstox API (alternative)
# UPSTOX_API_KEY=
# UPSTOX_API_SECRET=
